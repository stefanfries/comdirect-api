# Comdirect API credentials
CLIENT_ID = your_client_id
CLIENT_SECRET = your_client_secret

# Bank connection 1 — Erstdepot
ACCOUNTS__DEPOT11__ZUGANGSNUMMER = your_zugangsnummer
ACCOUNTS__DEPOT11__PIN = your_pin
ACCOUNTS__DEPOT11__DISPLAY_NAME = "My First Depot"

# Bank connection 1 — Zweitdepot (optional)
# ACCOUNTS__DEPOT12__ZUGANGSNUMMER = your_zugangsnummer
# ACCOUNTS__DEPOT12__PIN = your_pin
# ACCOUNTS__DEPOT12__DISPLAY_NAME = "My Second Depot"

# Bank connection 2 — Erstdepot (optional, separate Comdirect login)
# ACCOUNTS__DEPOT21__ZUGANGSNUMMER = your_zugangsnummer
# ACCOUNTS__DEPOT21__PIN = your_pin
# ACCOUNTS__DEPOT21__DISPLAY_NAME = "My Third Depot"

# MongoDB Atlas
MONGODB_CONNECTION_STRING = "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DATABASE = finance
